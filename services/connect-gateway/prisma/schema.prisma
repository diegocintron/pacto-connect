generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum KeyMode {
  live
  test
}

enum KeyStatus {
  active
  revoked
}

enum CheckoutMode {
  buy
  sell
}

enum SessionStatus {
  active
  expired
  consumed
  revoked
}

enum WebhookStatus {
  enabled
  disabled
}

enum WebhookDeliveryStatus {
  pending
  succeeded
  failed
  dead
}

enum IdempotencyStatus {
  pending
  completed
}

enum SubscriptionStatus {
  active
  past_due
  canceled
}

enum SubscriptionChargeStatus {
  succeeded
  failed
}

enum MerchantStatus {
  active
  disabled
}

model Merchant {
  id        String         @id @default(cuid())
  apiKeyId  String
  apiKey    ApiKey         @relation(fields: [apiKeyId], references: [id])
  name      String
  status    MerchantStatus @default(active)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  sessions         CheckoutSession[]
  webhookEndpoints WebhookEndpoint[]
  webhookEvents    WebhookEvent[]
  subscriptions    Subscription[]
  settlements      MerchantSettlement[]

  @@index([apiKeyId])
  @@index([status])
}

model MerchantSettlement {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  escrowId   String   @unique
  amount     Float
  asset      String
  settledAt  DateTime @default(now())

  @@index([merchantId])
}

model ApiKey {
  id             String           @id @default(cuid())
  publishableKey String           @unique
  secretKeyHash  String
  secretLast4    String
  mode           KeyMode          @default(test)
  allowedOrigins String[]
  status         KeyStatus        @default(active)
  label          String?
  quoteSpreadBps Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  checkoutSessions   CheckoutSession[]
  webhookEndpoints   WebhookEndpoint[]
  webhookEvents      WebhookEvent[]
  subscriptions      Subscription[]
  merchants          Merchant[]

  @@index([publishableKey])
  @@index([status])
}

model CheckoutSession {
  id               String        @id @default(cuid())
  apiKeyId         String
  apiKey           ApiKey        @relation(fields: [apiKeyId], references: [id])
  mode             CheckoutMode
  listingId        String?
  quote            Json?
  clientSecretHash String
  status           SessionStatus @default(active)
  expiresAt        DateTime
  refreshCount     Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  merchantId       String?
  merchant         Merchant?     @relation(fields: [merchantId], references: [id])

  @@index([apiKeyId])
  @@index([status])
  @@index([merchantId])
}

model WebhookEndpoint {
  id            String                @id @default(cuid())
  apiKeyId      String
  apiKey        ApiKey                @relation(fields: [apiKeyId], references: [id])
  url           String
  secret        String
  enabledEvents String[]
  status        WebhookStatus         @default(enabled)
  verified      Boolean               @default(false)
  description   String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deliveries    WebhookDelivery[]
  merchantId    String?
  merchant      Merchant?             @relation(fields: [merchantId], references: [id])

  @@index([apiKeyId])
  @@index([status])
  @@index([merchantId])
}

model WebhookEvent {
  id         String            @id @default(cuid())
  apiKeyId   String
  apiKey     ApiKey            @relation(fields: [apiKeyId], references: [id])
  type       String
  data       Json
  sourceEventId String? @unique
  createdAt  DateTime          @default(now())
  deliveries WebhookDelivery[]
  merchantId String?
  merchant   Merchant?         @relation(fields: [merchantId], references: [id])

  @@index([apiKeyId])
  @@index([type])
  @@index([merchantId])
}

model Subscription {
  id             String              @id @default(cuid())
  apiKeyId       String
  apiKey         ApiKey              @relation(fields: [apiKeyId], references: [id])
  sessionId      String
  payerRef       String?
  from           String
  to             String
  amount         Float
  asset          String              @default("USDC")
  interval       String
  status         SubscriptionStatus  @default(active)
  attemptCount   Int                 @default(0)
  failNextCharge Boolean             @default(false)
  nextChargeAt   DateTime
  canceledAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  charges        SubscriptionCharge[]
  merchantId     String?
  merchant       Merchant?           @relation(fields: [merchantId], references: [id])

  @@index([apiKeyId])
  @@index([status, nextChargeAt])
  @@index([merchantId])
}

model SubscriptionCharge {
  id             String                   @id @default(cuid())
  subscriptionId String
  subscription   Subscription             @relation(fields: [subscriptionId], references: [id])
  status         SubscriptionChargeStatus
  quote          Json
  escrowId       String?
  failureReason  String?
  attempt        Int
  createdAt      DateTime                 @default(now())

  @@index([subscriptionId])
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  endpointId     String
  endpoint       WebhookEndpoint       @relation(fields: [endpointId], references: [id])
  eventId        String
  event          WebhookEvent          @relation(fields: [eventId], references: [id])
  eventType      String
  status         WebhookDeliveryStatus @default(pending)
  attempts       Int                   @default(0)
  maxAttempts    Int                   @default(5)
  nextAttemptAt  DateTime              @default(now())
  lastError      String?
  lastStatusCode Int?
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status, nextAttemptAt])
  @@index([endpointId])
  @@index([eventId])
}

model IdempotencyRecord {
  id           String            @id @default(cuid())
  apiKeyId     String
  key          String
  requestHash  String
  status       IdempotencyStatus @default(pending)
  statusCode   Int?
  responseBody String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([apiKeyId, key])
  @@index([createdAt])
}

model WebhookNonce {
  id        String   @id @default(cuid())
  nonce     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
